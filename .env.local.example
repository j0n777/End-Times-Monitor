# =============================================================================
# END TIMES MONITOR - CONFIGURAÇÃO DE API
# =============================================================================
# Este arquivo contém todas as configurações necessárias para integração com
# as fontes de dados. Copie este arquivo para .env.local e preencha com suas
# credenciais reais.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (Banco de Dados)
# -----------------------------------------------------------------------------
# URL do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://bimfztwwzuwwefxfkkwe.supabase.co

# Chave publicável do Supabase (segura para uso no frontend)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key_here

# Chave de serviço do Supabase (use com cuidado - acesso total ao banco)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -----------------------------------------------------------------------------
# TELEGRAM BOT (Monitoramento de Canais)
# -----------------------------------------------------------------------------
# Token do bot do Telegram. Obtenha com @BotFather
# Formato: 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_TOKEN=your_token_here

# IDs dos canais para monitorar (separados por vírgula)
# Pode ser @nomedocanal ou -100123456789
# Exemplo: TELEGRAM_CHANNEL_IDS=@canalnoticias,@outrocanal,-100123456789
TELEGRAM_CHANNEL_IDS=channel1,channel2

# -----------------------------------------------------------------------------
# NASA FIRMS (Active Fires / Incêndios Ativos)
# -----------------------------------------------------------------------------
# Registre-se gratuitamente em: https://firms.modaps.eosdis.nasa.gov
# Fornece dados de incêndios ativos em tempo quase real (delay de 3-4 horas)
NASA_FIRMS_API_KEY=your_key_here

# -----------------------------------------------------------------------------
# NASA EONET (Earth Observatory Natural Event Tracker)
# -----------------------------------------------------------------------------
# API Key opcional para NASA EONET (funciona sem key, mas key aumenta rate limit)
# Registre-se em: https://api.nasa.gov
# Fornece: Incêndios, Tempestades, Vulcões, Enchentes, Secas
NASA_EONET_API_KEY=

# -----------------------------------------------------------------------------
# ACLED (Armed Conflict Location & Event Data)
# -----------------------------------------------------------------------------
# Registre-se gratuitamente em: https://acleddata.com
# Email usado no cadastro do ACLED
ACLED_EMAIL=your_email_here

# Chave de API do ACLED (fornecida após registro)
ACLED_API_KEY=your_key_here

# -----------------------------------------------------------------------------
# NEWS API (Coleta ampliada de notícias - LEGADO)
# -----------------------------------------------------------------------------
# Obtenha em: https://newsapi.org
# NOTA: Esta API é considerada legado, pode ser removida em versões futuras
NEWS_API_KEY=

# -----------------------------------------------------------------------------
# FLAGS DE HABILITAÇÃO DE FONTES DE DADOS
# -----------------------------------------------------------------------------
# Controle quais fontes de dados estão ativas (true/false)

# GDACS - Global Disaster Alert and Coordination System
# Fornece: Terremotos, Tsunamis, Ciclones, Enchentes, Vulcões
# Não requer autenticação
GDACS_ENABLED=true

# WHO - World Health Organization
# Fornece: Emergências de saúde, Epidemias, Pandemias
# Não requer autenticação
WHO_ENABLED=true

# GDELT - Global Database of Events, Language and Tone
# Fornece: Monitoramento de notícias globais em 100+ idiomas
# Não requer autenticação
GDELT_ENABLED=true

# Polymarket - Prediction Markets
# Fornece: Inteligência de mercado sobre conflitos, guerras, eventos políticos
# API pública gratuita, não requer autenticação
POLYMARKET_ENABLED=true

# -----------------------------------------------------------------------------
# WEATHER ALERTS (Alertas Meteorológicos Severos)
# -----------------------------------------------------------------------------
# NWS API (National Weather Service - USA)
# API gratuita, não requer chave. Fornece alertas de tornados, ventos fortes (>100km/h),
# chuvas intensas/floods para os Estados Unidos, com polígonos das áreas afetadas.
# Não requer autenticação
NWS_ENABLED=true

# Weatherbit API (Cobertura Global - Opcional)
# Registre-se em: https://www.weatherbit.io/api/weather-alerts
# Tier gratuito: 500 chamadas/dia
# Fornece alertas globais de clima severo (complementa NWS para regiões fora dos EUA)
WEATHERBIT_API_KEY=
WEATHERBIT_ENABLED=false
